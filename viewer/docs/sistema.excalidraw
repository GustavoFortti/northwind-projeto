    {
      "id": "Ac-VX6JKxJhNeWmN7Wmp9",
      "type": "text",
      "x": 5544.6943779002195,
      "y": -7495.94872638084,
      "width": 452.1241455078125,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
